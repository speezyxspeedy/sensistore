# Firebase Web App values are public identifiers, but each deployment must set them.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_ADMIN_EMAIL=bglspeedy@gmail.com

# Manual is the production-safe default until a server-side gateway is configured.
VITE_PAYMENT_MODE=manual

# Server-only payment variables. Never prefix secrets with VITE_.
PAYMENT_PROVIDER=
BHARATPE_MERCHANT_ID=
BHARATPE_API_KEY=
BHARATPE_REQUEST_SECRET=
BHARATPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Server-only Firebase Admin variables for Vercel functions.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
ADMIN_EMAIL=bglspeedy@gmail.com
