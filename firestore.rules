rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isAdmin() {
      return signedIn() && request.auth.token.email == 'bglspeedy@gmail.com';
    }
    function validPlanAndAmount() {
      return (request.resource.data.plan == 'normal' && request.resource.data.amount == 199)
        || (request.resource.data.plan == 'premium' && request.resource.data.amount == 499);
    }
    function validNewOrder(orderId) {
      return request.resource.data.keys().hasAll([
          'orderId', 'uid', 'customerName', 'email', 'phone', 'deviceName',
          'deviceModel', 'ram', 'androidVersion', 'gameName', 'plan', 'amount',
          'paymentProvider', 'paymentId', 'paymentStatus', 'orderStatus',
          'hudScreenshotUrl', 'sensiScreenshotUrl', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.orderId == orderId
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.paymentProvider == 'manual_upi'
        && request.resource.data.paymentStatus == 'Pending'
        && request.resource.data.orderStatus == 'Pending'
        && request.resource.data.paymentId is string
        && request.resource.data.paymentId.size() >= 6
        && validPlanAndAmount();
    }
    function validAdminOrderUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['paymentStatus', 'orderStatus', 'updatedAt'])
        && request.resource.data.paymentStatus in ['Pending', 'Paid', 'Failed']
        && request.resource.data.orderStatus in ['Pending', 'Processing', 'Delivered'];
    }

    match /users/{userId} {
      allow get: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email;
      allow update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email;
      allow delete: if false;
    }

    match /orders/{orderId} {
      allow get: if signedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow list: if signedIn() && (isAdmin() || resource.data.uid == request.auth.uid);
      allow create: if signedIn() && validNewOrder(orderId);
      allow update: if isAdmin() && validAdminOrderUpdate();
      allow delete: if false;
    }

    match /paymentSessions/{sessionId} { allow read, write: if false; }
    match /rateLimits/{limitId} { allow read, write: if false; }
  }
}
